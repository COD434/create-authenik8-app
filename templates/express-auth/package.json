{
  "name": "authenik8-app",
  "description": "Authenik8 generated Express auth app",
  "main": "dist/server.js",
  "type": "commonjs",
  "engines": {
    "node": "^20.19 || ^22.12 || >=24"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma db push && prisma generate",
    "prisma:migrate": "prisma db push && prisma generate",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "authenik8-core": "2.0.3",
    "dotenv": "^16.0.0",
    "express": "^4.19.2",
    "@prisma/client": "7.8.0",
    "ioredis": "^5.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.1",
    "ioredis-mock": "8.13.1",
    "prisma": "7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  }
}
