    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "@prisma/client": "7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0",
     "prisma": "7.8.0"

  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "type": "commonjs"
}
